<?xml version="1.0" encoding="UTF-8"?>
<component xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="racepoint_component_profile.xsd"
           manufacturer="Hisense"
           model="100U65QF"
           device_class="HD_monitor"
           minimum_component_engine_version="11.0"
           rpm_xml_version="1.2">
    <notes>
        Hisense 100U65QF (100" 4K Laser TV) - Android TV Remote v2 Bridge Driver

        SETUP NOTES FOR IP CONTROL:
        - This profile communicates via HTTP to a custom bridge service that
          translates HTTP commands to Android TV Remote v2 protocol (port 6466).
        - The bridge service must be running and accessible on the Savant host.
        - Default bridge port: 8642 (configurable in bridge service settings).
        - The TV must be paired with the bridge service before control is possible.

        REQUIREMENTS:
        - hisense-bridge service must be installed and running.
        - The Hisense TV must be connected to the network (wired recommended).
        - All bridge files are deployed to the Savant host at /home/RPM/tmp
        - Bridge service URL: http://localhost:8642
        - Python 3.8+ required on Savant host.

        PAIRING (one-time setup):
        1. Ensure the TV is fully powered on (screen showing home screen).
        2. Run: curl -X PUT http://localhost:8642/api/auth/pair
        3. A 6-character hex code will appear on the TV screen.
        4. Run: curl -X PUT 'http://localhost:8642/api/auth/confirm?pin=XXXXXX'
        5. Pairing is persistent - only needs to be done once.

        AVAILABLE INPUTS:
        - HDMI 1 (eARC) - supports ARC/eARC audio return
        - HDMI 2
        - HDMI 3
        - HDMI 4
        - Apps (internal smart TV apps via Home key)

        KNOWN LIMITATIONS:
        - Power On uses Wake-on-LAN; TV must have network standby enabled.
        - Volume is controlled via repeated key presses (no absolute set).
        - Mute uses toggle; state tracked via callbacks for discrete on/off.
        - No IR control available (TV uses Bluetooth remote only).

        ====================== Change Log ==================
        Version: 1.2 Change: Migrated from MQTT to Android TV Remote v2 protocol.  Risk: High Importance: Critical
    </notes>
    <component_properties>
        <always_repeat_input_selection>true</always_repeat_input_selection>
    </component_properties>
    <control_interfaces preferred="ip">
        <ip port="8642" response_time_length_ms="2000" protocol="http">
        </ip>
    </control_interfaces>
    <media_interfaces>
        <bidirectional name_on_component="HDMI 1 (eARC)">
            <combined_media>
                <audio_media type="hdmi_audio"></audio_media>
                <video_media type="hdmi"></video_media>
            </combined_media>
            <resource resource_type="AV_AMPLIFIER_FUNCTION"></resource>
            <resource resource_type="AV_MONITOR_SINK"></resource>
            <resource resource_type="AV_STEREOSPEAKERS_SINK"></resource>
            <resource resource_type="AV_VOLUMECONTROL_FUNCTION"></resource>
        </bidirectional>
        <input name_on_component="HDMI 2">
            <combined_media>
                <audio_media type="hdmi_audio"></audio_media>
                <video_media type="hdmi"></video_media>
            </combined_media>
            <resource resource_type="AV_AMPLIFIER_FUNCTION"></resource>
            <resource resource_type="AV_MONITOR_SINK"></resource>
            <resource resource_type="AV_STEREOSPEAKERS_SINK"></resource>
            <resource resource_type="AV_VOLUMECONTROL_FUNCTION"></resource>
        </input>
        <input name_on_component="HDMI 3">
            <combined_media>
                <audio_media type="hdmi_audio"></audio_media>
                <video_media type="hdmi"></video_media>
            </combined_media>
            <resource resource_type="AV_AMPLIFIER_FUNCTION"></resource>
            <resource resource_type="AV_MONITOR_SINK"></resource>
            <resource resource_type="AV_STEREOSPEAKERS_SINK"></resource>
            <resource resource_type="AV_VOLUMECONTROL_FUNCTION"></resource>
        </input>
        <input name_on_component="HDMI 4">
            <combined_media>
                <audio_media type="hdmi_audio"></audio_media>
                <video_media type="hdmi"></video_media>
            </combined_media>
            <resource resource_type="AV_AMPLIFIER_FUNCTION"></resource>
            <resource resource_type="AV_MONITOR_SINK"></resource>
            <resource resource_type="AV_STEREOSPEAKERS_SINK"></resource>
            <resource resource_type="AV_VOLUMECONTROL_FUNCTION"></resource>
        </input>
        <output name_on_component="DIGITAL AUDIO OUT">
            <audio_media type="optical_digital"></audio_media>
        </output>
        <internal name_on_component="Apps">
            <audio_media></audio_media>
            <video_media></video_media>
            <resource resource_type="AV_EXTERNALMEDIASERVER_SOURCE"></resource>
            <resource resource_type="AV_AMPLIFIER_FUNCTION"></resource>
            <resource resource_type="AV_MONITOR_SINK"></resource>
            <resource resource_type="AV_STEREOSPEAKERS_SINK"></resource>
            <resource resource_type="AV_VOLUMECONTROL_FUNCTION"></resource>
        </internal>
        <data name_on_component="LAN">
            <combined_media>
                <data_media type="ethernet"></data_media>
                <control port="8642"></control>
            </combined_media>
        </data>
    </media_interfaces>
    <state_variable_list>
        <state_variable name="Power_current_power_HD Monitor"
                       state_center_binding="CurrentPowerStatus"
                       state_center_type="string"
                       owning_logical_component="HD Monitor">OFF</state_variable>
        <state_variable name="Mute_current_mute_HD Monitor"
                       state_center_binding="CurrentMuteStatus"
                       state_center_type="string"
                       owning_logical_component="HD Monitor">OFF</state_variable>
        <volume_state_variable name="Volume_current_volume_HD Monitor"
                              state_center_binding="CurrentVolume"
                              state_center_type="integer"
                              owning_logical_component="HD Monitor"
                              granularity="1"
                              min_value="0"
                              max_value="100">0</volume_state_variable>
    </state_variable_list>
    <logical_component logical_component_name="HD Monitor">
        <implementation>
            <input name_on_component="HDMI 1 (eARC)">
                <action_to_select name="SelectInputHDMI1"></action_to_select>
            </input>
            <output name_on_component="HDMI 1 (eARC)"></output>
            <output name_on_component="DIGITAL AUDIO OUT"></output>
        </implementation>
        <implementation>
            <input name_on_component="HDMI 2">
                <action_to_select name="SelectInputHDMI2"></action_to_select>
            </input>
            <output name_on_component="HDMI 1 (eARC)"></output>
            <output name_on_component="DIGITAL AUDIO OUT"></output>
        </implementation>
        <implementation>
            <input name_on_component="HDMI 3">
                <action_to_select name="SelectInputHDMI3"></action_to_select>
            </input>
            <output name_on_component="HDMI 1 (eARC)"></output>
            <output name_on_component="DIGITAL AUDIO OUT"></output>
        </implementation>
        <implementation>
            <input name_on_component="HDMI 4">
                <action_to_select name="SelectInputHDMI4"></action_to_select>
            </input>
            <output name_on_component="HDMI 1 (eARC)"></output>
            <output name_on_component="DIGITAL AUDIO OUT"></output>
        </implementation>
        <implementation>
            <output name_on_component="HDMI 1 (eARC)"></output>
            <output name_on_component="DIGITAL AUDIO OUT"></output>
            <internal name_on_component="Apps">
                <action_to_select name="SelectInternalInputApps"></action_to_select>
            </internal>
        </implementation>
        <universal_component_actions>
            <action name="PowerOn">
                <execute_on_state_variable_condition name="Power_current_power_HD Monitor" test_condition="not_equal">ON</execute_on_state_variable_condition>
                <update_state_variable name="Power_current_power_HD Monitor" update_type="set" update_source="constant">ON</update_state_variable>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/power/on</command_string>
                        <delay ms_delay="8000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="PowerOff">
                <execute_on_state_variable_condition name="Power_current_power_HD Monitor" test_condition="not_equal">OFF</execute_on_state_variable_condition>
                <update_state_variable name="Power_current_power_HD Monitor" update_type="set" update_source="constant">OFF</update_state_variable>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/power/off</command_string>
                        <delay ms_delay="3000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="GetState">
                <command_interface interface="ip">
                    <command response_required="yes">
                        <command_string type="character" http_request_type="GET">api/state</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
                <execute_on_schedule period_ms="0"></execute_on_schedule>
                <execute_on_schedule period_ms="10000"></execute_on_schedule>
            </action>
        </universal_component_actions>
        <resource_component_actions resource_type="AV_VOLUMECONTROL_FUNCTION">
            <action name="SetVolume">
                <action_argument name="VolumeValue" note="Volume level 0-100"/>
                <update_state_variable name="Mute_current_mute_HD Monitor" update_type="set" update_source="constant">OFF</update_state_variable>
                <update_volume_variables name="Volume_current_volume_HD Monitor" update_type="set" update_source="action_argument">VolumeValue</update_volume_variables>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/volume/set?value=</command_string>
                        <parameter_list>
                            <volume_parameter action_argument="VolumeValue"
                                            volume_state_variable="Volume_current_volume_HD Monitor"
                                            parameter_data_type="character"
                                            parameter_total_width="3"
                                            parameter_data_width="3"
                                            parameter_justify="right"
                                            parameter_fill="0"/>
                        </parameter_list>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="IncreaseVolume">
                <update_state_variable name="Mute_current_mute_HD Monitor" update_type="set" update_source="constant">OFF</update_state_variable>
                <update_volume_variables name="Volume_current_volume_HD Monitor" update_type="increment" update_source="constant">1</update_volume_variables>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/volume/up</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="DecreaseVolume">
                <update_state_variable name="Mute_current_mute_HD Monitor" update_type="set" update_source="constant">OFF</update_state_variable>
                <update_volume_variables name="Volume_current_volume_HD Monitor" update_type="decrement" update_source="constant">1</update_volume_variables>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/volume/down</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="MuteOn">
                <execute_on_state_variable_condition name="Mute_current_mute_HD Monitor" test_condition="not_equal">ON</execute_on_state_variable_condition>
                <update_state_variable name="Mute_current_mute_HD Monitor" update_type="set" update_source="constant">ON</update_state_variable>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/mute/on</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="MuteOff">
                <execute_on_state_variable_condition name="Mute_current_mute_HD Monitor" test_condition="not_equal">OFF</execute_on_state_variable_condition>
                <update_state_variable name="Mute_current_mute_HD Monitor" update_type="set" update_source="constant">OFF</update_state_variable>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/mute/off</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
        </resource_component_actions>
        <resource_component_actions resource_type="AV_EXTERNALMEDIASERVER_SOURCE">
            <action name="OSDCursorUp">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/up</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="OSDCursorDown">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/down</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="OSDCursorLeft">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/left</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="OSDCursorRight">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/right</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="Select">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/ok</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="Back">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/back</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="Exit">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/exit</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="Menu">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/menu</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="Home">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/nav/home</command_string>
                        <delay ms_delay="200"></delay>
                    </command>
                </command_interface>
            </action>
        </resource_component_actions>
        <custom_component_actions>
            <action name="SelectInputHDMI1">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/input/select?source=HDMI1</command_string>
                        <delay ms_delay="1000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="SelectInputHDMI2">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/input/select?source=HDMI2</command_string>
                        <delay ms_delay="1000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="SelectInputHDMI3">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/input/select?source=HDMI3</command_string>
                        <delay ms_delay="1000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="SelectInputHDMI4">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/input/select?source=HDMI4</command_string>
                        <delay ms_delay="1000"></delay>
                    </command>
                </command_interface>
            </action>
            <action name="SelectInternalInputApps">
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character" http_request_type="PUT">api/input/select?source=Apps</command_string>
                        <delay ms_delay="1000"></delay>
                    </command>
                </command_interface>
            </action>
        </custom_component_actions>
    </logical_component>
    <status_messages>
        <status_message name="StateResponse">
            <root_object name="state" format="json" matches_required="at_least_one">
                <values path="/power" matches_required="at_least_one">
                    <data_map match_required="no">
                        <map key="ON">
                            <update state="CurrentPowerStatus" type="string">ON</update>
                        </map>
                        <map key="OFF">
                            <update state="CurrentPowerStatus" type="string">OFF</update>
                        </map>
                        <map key="PENDING">
                            <update state="CurrentPowerStatus" type="string">ON</update>
                        </map>
                    </data_map>
                </values>
                <values path="/volume" matches_required="at_least_one">
                    <update state="CurrentVolume" type="integer"></update>
                </values>
                <values path="/mute" matches_required="at_least_one">
                    <data_map match_required="no">
                        <map key="ON">
                            <update state="CurrentMuteStatus" type="string">ON</update>
                        </map>
                        <map key="OFF">
                            <update state="CurrentMuteStatus" type="string">OFF</update>
                        </map>
                    </data_map>
                </values>
            </root_object>
        </status_message>
    </status_messages>
</component>
